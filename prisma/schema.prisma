
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User { 
  id    String     @id @default(uuid()) 
  email String  @unique
  name  String?
} 
model Document {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
}